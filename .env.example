# ============================================================
# SMS-EDU FRONTEND — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# --- Supabase (Master Registry) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Backend API (Express.js) ---
NEXT_PUBLIC_BACKEND_URL=http://localhost:5000/api

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SMS-Edu
NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000

# --- Multi-Tenancy Security ---
MASTER_ENCRYPTION_KEY=your-64-char-hex-encryption-key

# --- Resend Email ---
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# --- Internal Auth (S2S shared secret with backend) ---
INTERNAL_AUTH_SECRET=your-internal-shared-secret
